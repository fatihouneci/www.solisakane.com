<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>You're Invited to Join <%= appName %>!</title>
    <style>
      body {
        font-family: Arial, sans-serif;
        background-color: #f6f8fb;
        margin: 0;
        padding: 0;
      }
      .container {
        max-width: 600px;
        margin: 40px auto;
        background-color: #ffffff;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
      }
      .header {
        background-color: #1d4ed8;
        color: white;
        padding: 20px;
        text-align: center;
      }
      .content {
        padding: 30px;
      }
      .btn {
        display: inline-block;
        margin-top: 20px;
        background-color: #1d4ed8;
        color: white;
        padding: 12px 24px;
        text-decoration: none;
        border-radius: 6px;
        font-weight: bold;
      }
      .footer {
        text-align: center;
        font-size: 12px;
        color: #999;
        margin-top: 30px;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="header">
        <img
          src="<%= logoUrl %>"
          alt="<%= appName %> Logo"
          style="height: 50px; margin-bottom: 10px"
        />
        <h1>Welcome to <%= appName %>!</h1>
      </div>
      <div class="content">
        <p>Hello,</p>
        <p>
          <%= sender.fullName %>  have been invited to join the
          <strong><%= appName %></strong> platform. Click the button below to
          accept your invitation and create your account:
        </p>

        <a href="<%= inviteLink %>" class="btn">Accept Invitation</a>

        <p style="margin-top: 20px">
          If the button doesn't work, copy and paste this URL into your browser:
          <br />
          <a href="<%= inviteLink %>"><%= inviteLink %></a>
        </p>

        <p>
          This invitation will expire in <%= expirationHours || 24 %> hours.
        </p>

        <p>Looking forward to having you on board,</p>
        <p>The <%= appName %> Team</p>
      </div>

      <div class="footer">
        © <%= new Date().getFullYear() %> <%= appName %>. All rights reserved.
      </div>
    </div>
  </body>
</html>
